# Sales Training Dashboard — environment variables
# Copy this file to `.env` and fill in. Never commit `.env`.

# ─── Supabase ─────────────────────────────────────────────────────────────
# Public project URL. Already provisioned.
SUPABASE_URL=https://wuxkcrbarsutnvxzzmly.supabase.co

# Service role key — required by the sync script ONLY.
# Find in: Supabase dashboard → Project Settings → API → "service_role" key
# Treat as a server-only secret. Do NOT expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Anon key — used by the frontend (Vite VITE_* prefix).
# Find in: Supabase dashboard → Project Settings → API → "anon public" key
VITE_SUPABASE_URL=https://wuxkcrbarsutnvxzzmly.supabase.co
VITE_SUPABASE_ANON_KEY=

# Switch the dashboard between CSV-seed (dev) and Supabase (prod).
# Set to "supabase" once you've run the sync script at least once.
VITE_DATA_SOURCE=supabase

# ─── Google Sheet ─────────────────────────────────────────────────────────
SHEET_ID=1csEE13PjyMUfMlgjeM7oW7Xlfb9DNUAUZ_9J9-wVzzo
